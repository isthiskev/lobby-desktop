{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lobby",
  "identifier": "gg.lobby.desktop",
  "version": "0.1.5",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Lobby",
        "url": "https://lobby-web.vercel.app/?shell=desktop",
        "userAgent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/126.0.0.0 Safari/537.36 LobbyDesktop/0.1.5",
        "width": 1440,
        "height": 810,
        "resizable": false,
        "maximizable": false,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ]
  }
}
